# ============================================================
# CiT-SMS — Environment Variables Template
# Sao chép file này thành .env.local (dev) hoặc .env (prod)
# TUYỆT ĐỐI KHÔNG điền giá trị thật vào file này
# ============================================================

# --- DATABASE (Hostinger MySQL 8) ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=""

# --- NEXTAUTH v5 ---
# Tạo bằng: openssl rand -base64 32
AUTH_SECRET=""
# URL công khai của ứng dụng (không có dấu / cuối)
AUTH_URL="https://your-domain.com"

# --- BẢO MẬT CCCD ---
# Khóa mã hóa AES-256-GCM (32 bytes, base64)
# Tạo bằng: openssl rand -base64 32
CCCD_ENCRYPTION_KEY=""
# Khóa blind index HMAC (32 bytes, base64)
# Tạo bằng: openssl rand -base64 32
CCCD_INDEX_KEY=""

# --- AI (Google Gemini) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
